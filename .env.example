VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key

# --- Claude API (Anthropic) ---
# Get from: https://console.anthropic.com/ → API Keys
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...your-key
